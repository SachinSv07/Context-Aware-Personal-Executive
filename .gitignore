# .gitignore for Context-Aware Personal Executive

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Testing
.pytest_cache/
.coverage
htmlcov/

# Jupyter Notebook
.ipynb_checkpoints

# Database
*.db
*.sqlite

# User data (if storing actual personal data)
sample_data/*.pdf
!sample_data/README_PDF.txt

# OAuth credentials (sensitive data)
backend/data/oauth_app_config.json
backend/data/oauth_credentials.json

# User uploaded files (sensitive/personal data)
uploads/
backend/data/conversations.json
backend/data/files.json
backend/data/users.json
backend/data/notes.json
backend/data/data_sources.json

# Gmail/Drive/Calendar tokens (sensitive)
*_token.json
*.json.token
sample_data/*_token.json
backend/data/*_token.json

# .gitignore for Context-Aware Personal Executive

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Testing
.pytest_cache/
.coverage
htmlcov/

# Jupyter Notebook
.ipynb_checkpoints

# Database
*.db
*.sqlite

# Node
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-error.log*

# OAuth credentials and secrets (never commit these)
backend/data/oauth_credentials.json
backend/data/oauth_app_config.json

# User data (if storing actual personal data)
sample_data/*.pdf
!sample_data/README_PDF.txt
